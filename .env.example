# Weather Platform — Environment Variables
# Copy to .env and fill in your values

# Database URLs (Docker Compose defaults)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/weatherdb
TIMESCALE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/metricsdb

# External API Keys
OPENWEATHER_API_KEY=your_openweathermap_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000
